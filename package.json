{
	"name": "@schemd/core",
	"version": "0.1.1",
	"description": "Zero-dependency text-to-SVG compiler for schematics and UML.",
	"homepage": "https://johnowolabiidogun.dev/tools/schemd/docs/overview",
	"bugs": {
		"url": "https://github.com/Sirneij/schemd/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Sirneij/schemd.git"
	},
	"type": "module",
	"sideEffects": false,
	"browser": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./parser": {
			"types": "./dist/parser.d.ts",
			"import": "./dist/parser.js"
		},
		"./renderer": {
			"types": "./dist/renderer.d.ts",
			"import": "./dist/renderer.js"
		},
		"./layout": {
			"types": "./dist/layout.d.ts",
			"import": "./dist/layout.js"
		},
		"./math-label": {
			"types": "./dist/math-label.d.ts",
			"import": "./dist/math-label.js"
		},
		"./marked": {
			"types": "./dist/marked-extension.d.ts",
			"import": "./dist/marked-extension.js"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"import": "./dist/types.js"
		}
	},
	"scripts": {
		"build": "node -e \"require('node:fs').rmSync('dist',{ recursive: true, force: true })\" && tsc -p tsconfig.build.json && tsc -p tsconfig.types.json",
		"check": "tsc -p tsconfig.json --noEmit",
		"prepack": "npm run build",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage"
	},
	"peerDependencies": {
		"marked": ">=17 <19"
	},
	"peerDependenciesMeta": {
		"marked": {
			"optional": true
		}
	},
	"devDependencies": {
		"@vitest/coverage-v8": "^4.1.10",
		"marked": "^18.0.6",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10"
	},
	"engines": {
		"node": ">=24"
	},
	"keywords": [
		"schemd",
		"marked",
		"schematic",
		"svg",
		"compiler",
		"engineering",
		"uml"
	],
	"license": "MIT"
}
